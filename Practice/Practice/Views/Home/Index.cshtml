@model List<Vehicle>

@section title{
    List
}

<ul>
    <li><a class="" asp-action="Vehicle" asp-controller="Home" asp-route-name="BMW" asp-route-id="1">Car</a></li>
    <li><a class="" asp-action="Vehicle" asp-controller="Home" asp-route-id="2" asp-route-name="Bajaj">Motorbike</a></li>
    <li><a href="/home/vehicle/3/titanic">Ship</a></li>
</ul>

<table>
    <tr>
        <td>ID</td>
        <td>Name</td>
        <td>Price</td>
    </tr>
    @foreach (var vehicle in Model)
    {
        <tr>
            <td>@vehicle.Id</td>
            <td>@vehicle.Name</td>
            <td>@vehicle.Price</td>
        </tr>
    }
    
</table>